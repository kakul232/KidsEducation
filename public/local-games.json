[
  {
    "id": "Ballon-counting",
    "title": "Balloon Pop Arithmetic",
    "topic": "Arithmetic",
    "subject": "Mathematics",
    "age": 5,
    "difficulty": "Medium",
    "htmlContent": "<!DOCTYPE html>\r\n<html>\r\n\r\n<head>\r\n    <meta charset=\"utf-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\r\n    <title>Balloon Pop Arithmetic</title>\r\n    <style>\r\n        body {\r\n            font-family: 'Arial', sans-serif;\r\n            margin: 0;\r\n            background: #0f172a;\r\n            color: #ffffff;\r\n            display: flex;\r\n            flex-direction: column;\r\n            align-items: center;\r\n            justify-content: center;\r\n            height: 100vh;\r\n            overflow: hidden;\r\n            touch-action: none;\r\n        }\r\n\r\n        .container {\r\n            width: 100%;\r\n            max-width: 360px;\r\n            height: 100%;\r\n            max-height: 640px;\r\n            display: flex;\r\n            flex-direction: column;\r\n            justify-content: space-between;\r\n            padding: 15px;\r\n            box-sizing: border-box;\r\n        }\r\n\r\n        #screen,\r\n        #game {\r\n            width: 100%;\r\n            height: 100%;\r\n            display: flex;\r\n            flex-direction: column;\r\n            justify-content: space-between;\r\n            align-items: center;\r\n        }\r\n\r\n        h1 {\r\n            color: #f1c40f;\r\n            font-size: 2.2rem;\r\n            margin: 20px 0 10px 0;\r\n            text-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);\r\n        }\r\n\r\n        p {\r\n            font-size: 1.2rem;\r\n            color: #cbd5e1;\r\n            margin: 0 10px;\r\n            line-height: 1.5;\r\n        }\r\n\r\n        .large-btn {\r\n            padding: 20px;\r\n            width: 100%;\r\n            font-size: 1.6rem;\r\n            font-weight: bold;\r\n            border: none;\r\n            border-radius: 16px;\r\n            background: #e74c3c;\r\n            color: white;\r\n            cursor: pointer;\r\n            box-shadow: 0 6px #c0392b;\r\n            transition: all 0.1s;\r\n            user-select: none;\r\n            -webkit-user-select: none;\r\n        }\r\n\r\n        .large-btn:active {\r\n            transform: translateY(4px);\r\n            box-shadow: 0 2px #c0392b;\r\n        }\r\n\r\n        #hud {\r\n            width: 100%;\r\n            display: flex;\r\n            justify-content: space-between;\r\n            align-items: center;\r\n            background: #1e293b;\r\n            padding: 12px;\r\n            border-radius: 12px;\r\n            box-sizing: border-box;\r\n            font-size: 1.3rem;\r\n            font-weight: bold;\r\n        }\r\n\r\n        #target-box {\r\n            font-size: 1.3rem;\r\n            color: #f1c40f;\r\n            background: #1e293b;\r\n            width: 100%;\r\n            padding: 12px;\r\n            border-radius: 12px;\r\n            font-weight: bold;\r\n            box-sizing: border-box;\r\n            border: 2px dashed #f1c40f;\r\n            margin: 5px 0;\r\n        }\r\n\r\n        canvas {\r\n            background: linear-gradient(#1e3a8a, #3b82f6);\r\n            border: 4px solid #1e293b;\r\n            border-radius: 16px;\r\n            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.4);\r\n            touch-action: none;\r\n        }\r\n\r\n        #overlay {\r\n            position: fixed;\r\n            inset: 0;\r\n            background: rgba(0, 0, 0, 0.8);\r\n            display: none;\r\n            align-items: center;\r\n            justify-content: center;\r\n            padding: 20px;\r\n            z-index: 10;\r\n        }\r\n\r\n        #card {\r\n            background: #1e293b;\r\n            padding: 30px 20px;\r\n            border-radius: 24px;\r\n            border: 4px solid #f1c40f;\r\n            width: 100%;\r\n            max-width: 300px;\r\n            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);\r\n            text-align: center;\r\n        }\r\n    </style>\r\n</head>\r\n\r\n<body>\r\n\r\n    <div class=\"container\">\r\n        <div id=\"screen\" style=\"display: flex;\">\r\n            <div>\r\n                <h1>🎈 Balloon Pop</h1>\r\n                <p>Tap directly on the floating balloons to pop them! Combine numbers to match the target sum!</p>\r\n            </div>\r\n            <div style=\"font-size: 80px; margin: 20px 0;\">🎈</div>\r\n            <button id=\"start\" class=\"large-btn\" style=\"background: #2ecc71; box-shadow: 0 6px #27ae60;\">▶ Play\r\n                Game</button>\r\n        </div>\r\n\r\n        <div id=\"game\" style=\"display: none;\">\r\n            <div id=\"hud\">\r\n                <span id=\"scoreEl\" style=\"color: #2ecc71;\">🎈 Popped: 0</span>\r\n                <span id=\"starsEl\" style=\"color: #f1c40f;\">⭐ 0</span>\r\n            </div>\r\n            <div id=\"target-box\">🎯 Target Sum: --</div>\r\n\r\n            <canvas id=\"cv\"></canvas>\r\n\r\n            <div style=\"font-size: 1.1rem; color: #94a3b8; margin: 10px 0; font-weight: bold;\">👋 Tap the balloons\r\n                directly!</div>\r\n        </div>\r\n    </div>\r\n\r\n    <div id=\"overlay\">\r\n        <div id=\"card\">\r\n            <h2 id=\"title\" style=\"font-size: 2rem; margin-top: 0; color: #f1c40f;\">🧩 Puzzle</h2>\r\n            <div id=\"content\"></div>\r\n        </div>\r\n    </div>\r\n\r\n    <script>\r\n        const cv = document.getElementById('cv'), ctx = cv.getContext('2d');\r\n        const scoreEl = document.getElementById('scoreEl');\r\n        const starsEl = document.getElementById('starsEl');\r\n        const targetBox = document.getElementById('target-box');\r\n        const overlay = document.getElementById('overlay');\r\n        const title = document.getElementById('title');\r\n        const content = document.getElementById('content');\r\n        const mainMenuScreen = document.getElementById('screen');\r\n        const gameScreen = document.getElementById('game');\r\n\r\n        // Setup sizing layout parameters safely\r\n        const cWidth = Math.min(innerWidth - 30, 330);\r\n        const cHeight = Math.min(innerHeight - 220, 380);\r\n        cv.width = cWidth;\r\n        cv.height = cHeight;\r\n\r\n        let balloons = [], score = 0, stars = 0, targetSum = 0, currentRunningSum = 0, run = false, paused = false;\r\n        const colors = ['#ff7675', '#74b9ff', '#a29bfe', '#00b894', '#fdcb6e'];\r\n\r\n        function init() {\r\n            balloons = [];\r\n            score = 0;\r\n            stars = 0;\r\n            currentRunningSum = 0;\r\n            pickRandomTarget();\r\n            scoreEl.textContent = '🎈 Popped: 0';\r\n            starsEl.textContent = '⭐ 0';\r\n        }\r\n\r\n        function pickRandomTarget() {\r\n            targetSum = Math.floor(Math.random() * 10) + 6;\r\n            updateTargetUI();\r\n        }\r\n\r\n        // UI text injection safely caught via variables \r\n        function updateTargetUI() {\r\n            if (targetBox) {\r\n                targetBox.innerText = `🎯 Target: Get numbers adding to ${targetSum}!\\n(Collected: ${currentRunningSum})`;\r\n            }\r\n        }\r\n\r\n        function spawnBalloon() {\r\n            if (balloons.length >= 5) return;\r\n\r\n            let radiusX = 24;\r\n            let radiusY = 30;\r\n            let spawnX = radiusX + Math.random() * (cWidth - radiusX * 2);\r\n\r\n            if (balloons.some(b => Math.abs(b.x - spawnX) < 45 && b.y > cHeight - 50)) return;\r\n\r\n            let val = Math.floor(Math.random() * (targetSum - 1)) + 1;\r\n            if (val > 9) val = Math.floor(Math.random() * 8) + 1;\r\n\r\n            balloons.push({\r\n                x: spawnX,\r\n                y: cHeight + 40,\r\n                rx: radiusX,\r\n                ry: radiusY,\r\n                v: val,\r\n                speed: 1.0 + Math.random() * 1.2,\r\n                color: colors[Math.floor(Math.random() * colors.length)]\r\n            });\r\n        }\r\n\r\n        function draw() {\r\n            ctx.clearRect(0, 0, cWidth, cHeight);\r\n\r\n            balloons.forEach(b => {\r\n                ctx.fillStyle = b.color;\r\n                ctx.beginPath();\r\n                ctx.ellipse(b.x, b.y, b.rx, b.ry, 0, 0, Math.PI * 2);\r\n                ctx.fill();\r\n\r\n                ctx.beginPath();\r\n                ctx.moveTo(b.x, b.y + b.ry);\r\n                ctx.lineTo(b.x - 5, b.y + b.ry + 6);\r\n                ctx.lineTo(b.x + 5, b.y + b.ry + 6);\r\n                ctx.closePath();\r\n                ctx.fill();\r\n\r\n                ctx.strokeStyle = '#e2e8f0';\r\n                ctx.lineWidth = 1.5;\r\n                ctx.beginPath();\r\n                ctx.moveTo(b.x, b.y + b.ry + 6);\r\n                ctx.lineTo(b.x, b.y + b.ry + 25);\r\n                ctx.stroke();\r\n\r\n                ctx.fillStyle = '#ffffff';\r\n                ctx.font = 'bold 22px Arial';\r\n                ctx.textAlign = 'center';\r\n                ctx.textBaseline = 'middle';\r\n                ctx.shadowColor = 'rgba(0, 0, 0, 0.4)';\r\n                ctx.shadowBlur = 4;\r\n                ctx.fillText(b.v, b.x, b.y);\r\n                ctx.shadowBlur = 0;\r\n            });\r\n        }\r\n\r\n        function updatePhysics() {\r\n            for (let i = balloons.length - 1; i >= 0; i--) {\r\n                balloons[i].y -= balloons[i].speed;\r\n                if (balloons[i].y < -40) {\r\n                    balloons.splice(i, 1);\r\n                }\r\n            }\r\n\r\n            if (Math.random() < 0.025) {\r\n                spawnBalloon();\r\n            }\r\n        }\r\n\r\n        function handleInteraction(clickX, clickY) {\r\n            if (!run || paused) return;\r\n\r\n            for (let i = balloons.length - 1; i >= 0; i--) {\r\n                let b = balloons[i];\r\n                let dx = (clickX - b.x) / b.rx;\r\n                let dy = (clickY - b.y) / b.ry;\r\n\r\n                if ((dx * dx + dy * dy) <= 1) {\r\n                    popEffect(b.v);\r\n                    balloons.splice(i, 1);\r\n                    break;\r\n                }\r\n            }\r\n        }\r\n\r\n        function popEffect(val) {\r\n            score++;\r\n            scoreEl.textContent = '🎈 Popped: ' + score;\r\n\r\n            if (currentRunningSum === 0) {\r\n                currentRunningSum = val;\r\n            } else {\r\n                let combined = currentRunningSum + val;\r\n                if (combined === targetSum) {\r\n                    stars++;\r\n                    starsEl.textContent = '⭐ ' + stars;\r\n                    currentRunningSum = 0;\r\n                    triggerPopup('✨ Perfect Match!', '#2ecc71', `Awesome! You hit the ${targetSum} goal!`);\r\n                } else if (combined > targetSum) {\r\n                    currentRunningSum = 0;\r\n                    triggerPopup('💥 Over Target!', '#e74c3c', `Oops, ${combined} went over ${targetSum}! Let's try a fresh target.`);\r\n                } else {\r\n                    currentRunningSum = combined;\r\n                }\r\n            }\r\n            updateTargetUI();\r\n        }\r\n\r\n        function triggerPopup(msg, color, subtitle) {\r\n            paused = true;\r\n            overlay.style.display = 'flex';\r\n            title.textContent = msg;\r\n            title.style.color = color;\r\n            content.innerHTML = `<p>${subtitle}</p><button class=\"large-btn\" style=\"margin-top:15px; background:${color}; box-shadow: 0 4px rgba(0,0,0,0.2);\" onclick=\"dismissPopup()\">Next Challenge</button>`;\r\n        }\r\n\r\n        function dismissPopup() {\r\n            overlay.style.display = 'none';\r\n            paused = false;\r\n            if (stars >= 5) {\r\n                endGame();\r\n            } else {\r\n                pickRandomTarget();\r\n            }\r\n        }\r\n\r\n        function endGame() {\r\n            run = false;\r\n            overlay.style.display = 'flex';\r\n            title.textContent = '🏆 Math Superstar!';\r\n            title.style.color = '#f1c40f';\r\n            content.innerHTML = '<p>Incredible! You collected 5 Stars perfectly!</p><button class=\"large-btn\" onclick=\"restart()\">Play Again</button>';\r\n            parent.postMessage({ type: 'game_complete', success: true }, '*');\r\n        }\r\n\r\n        function restart() {\r\n            overlay.style.display = 'none';\r\n            init();\r\n            run = true;\r\n            paused = false;\r\n        }\r\n\r\n        function loop() {\r\n            requestAnimationFrame(loop);\r\n            if (!run || paused) return;\r\n            updatePhysics();\r\n            draw();\r\n        }\r\n\r\n        // Fixed Play Button Event Trigger\r\n        document.getElementById('start').addEventListener('click', function (e) {\r\n            e.preventDefault();\r\n            mainMenuScreen.style.display = 'none';\r\n            gameScreen.style.display = 'flex';\r\n            init();\r\n            run = true;\r\n        });\r\n\r\n        // Native Mobile Touch Interaction \r\n        cv.addEventListener('touchstart', (e) => {\r\n            e.preventDefault();\r\n            const rect = cv.getBoundingClientRect();\r\n            const touch = e.touches[0];\r\n            const tx = touch.clientX - rect.left;\r\n            const ty = touch.clientY - rect.top;\r\n            handleInteraction(tx, ty);\r\n        }, { passive: false });\r\n\r\n        // Desktop Mouse Interaction Fallback\r\n        cv.addEventListener('mousedown', (e) => {\r\n            const rect = cv.getBoundingClientRect();\r\n            const mx = e.clientX - rect.left;\r\n            const my = e.clientY - rect.top;\r\n            handleInteraction(mx, my);\r\n        });\r\n\r\n        // Fire layout engine loops safely\r\n        requestAnimationFrame(loop);\r\n    </script>\r\n\r\n</body>\r\n\r\n</html>",
    "published": true,
    "createdAt": "2026-06-27T19:42:54.776Z"
  },
  {
    "id": "catch-the-number",
    "title": "Catch the Number",
    "topic": "Arithmetic",
    "subject": "Mathematics",
    "age": 5,
    "difficulty": "Medium",
    "htmlContent": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\"><title>Catch the Number</title><style>body{margin:0;padding:0;background:#f0f9ff;font-family:Arial, sans-serif;touch-action:none;overflow:hidden;display:flex;flex-direction:column;align-items:center;height:100vh;}#game-container{width:100%;max-width:400px;height:100%;display:flex;flex-direction:column;align-items:center;}#header{padding:20px;text-align:center;font-size:24px;font-weight:bold;color:#0284c7;}#hud{font-size:20px;margin-bottom:10px;color:#0369a1;}canvas{background:#fff;border:4px solid #bae6fd;border-radius:20px;width:90%;max-width:360px;touch-action:none;}.overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(255,255,255,0.9);display:flex;flex-direction:column;justify-content:center;align-items:center;z-index:10;text-align:center;padding:20px;box-sizing:border-box;}button{padding:15px 30px;font-size:20px;border-radius:20px;border:none;background:#22c55e;color:white;font-weight:bold;cursor:pointer;box-shadow:0 6px #166534;}button:active{transform:translateY(4px);box-shadow:0 2px #166534;}</style></head><body><div id=\"game-container\"><div id=\"header\">🔢 Catch the Number!</div><div id=\"hud\">Goal: Catch <span id=\"target-val\">-</span></div><canvas id=\"cv\"></canvas></div><div id=\"overlay\" class=\"overlay\"><h2 id=\"msg\">Ready?</h2><button onclick=\"startGame()\">Start Game</button></div><script>const cv=document.getElementById('cv'),ctx=cv.getContext('2d');const targetEl=document.getElementById('target-val'),overlay=document.getElementById('overlay'),msgEl=document.getElementById('msg');let target=8,score=0,balls=[],run=false;cv.width=360;cv.height=450;function spawn(){if(Math.random()<0.03){let val=Math.floor(Math.random()*10)+1;balls.push({x:Math.random()*(cv.width-40)+20,y:-40,val:val,r:25,speed:1.5+score*0.2});}}function startGame(){score=0;target=8;run=true;overlay.style.display='none';targetEl.textContent=target;}function draw(){ctx.clearRect(0,0,cv.width,cv.height);balls.forEach(b=>{ctx.fillStyle=b.val===target?'#22c55e':'#f43f5e';ctx.beginPath();ctx.arc(b.x,b.y,b.r,0,Math.PI*2);ctx.fill();ctx.fillStyle='white';ctx.textAlign='center';ctx.textBaseline='middle';ctx.font='bold 20px Arial';ctx.fillText(b.val,b.x,b.y);});}function update(){if(!run)return;balls.forEach(b=>b.y+=b.speed);balls=balls.filter(b=>b.y<cv.height+50);spawn();if(score>=10){run=false;msgEl.textContent='🎉 You won! You are a Math Master!';overlay.style.display='flex';parent.postMessage({type:'game_complete',success:true,correctCount:10,incorrectCount:0},'*');}}cv.addEventListener('touchstart',e=>{e.preventDefault();const rect=cv.getBoundingClientRect();const tx=e.touches[0].clientX-rect.left,ty=e.touches[0].clientY-rect.top;balls.forEach((b,i)=>{const dist=Math.hypot(b.x-tx,b.y-ty);if(dist<b.r+20){if(b.val===target){score++;target=Math.max(1,target-1);targetEl.textContent=target;balls.splice(i,1);parent.postMessage({type:'game_complete',success:true,correctCount:1,incorrectCount:0},'*');}else{parent.postMessage({type:'game_attempt',success:false},'*');}}});},{passive:false});function loop(){update();draw();requestAnimationFrame(loop);}loop();</script></body></html>",
    "published": true,
    "createdAt": "2026-06-27T19:42:54.780Z"
  },
  {
    "id": "Frog-Hopper",
    "title": "Happy Frog Hopper - 3 Logs Counting",
    "topic": "Counting",
    "subject": "Mathematics",
    "age": 5,
    "difficulty": "Easy",
    "htmlContent": "<!doctype html>\r\n<html>\r\n\r\n<head>\r\n    <meta charset=\"utf-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no\">\r\n    <title>Happy Frog Hopper - 3 Logs Counting</title>\r\n    <style>\r\n        body {\r\n            font-family: 'Comic Sans MS', Arial, sans-serif;\r\n            margin: 0;\r\n            background: #e8f5e9;\r\n            text-align: center;\r\n            color: #333;\r\n            overflow: hidden;\r\n            touch-action: none;\r\n        }\r\n\r\n        #screen,\r\n        #game {\r\n            display: none;\r\n            padding: 10px;\r\n            box-sizing: border-box;\r\n            width: 100%;\r\n            max-width: 360px;\r\n            margin: 0 auto;\r\n            height: 100vh;\r\n        }\r\n\r\n        #game {\r\n            display: none;\r\n            flex-direction: column;\r\n            justify-content: flex-start;\r\n            gap: 6px;\r\n            align-items: center;\r\n        }\r\n\r\n        h1 {\r\n            color: #2e7d32;\r\n            font-size: 32px;\r\n            margin: 10px 0 5px 0;\r\n        }\r\n\r\n        button {\r\n            padding: 16px 32px;\r\n            font-size: 22px;\r\n            font-weight: bold;\r\n            border-radius: 20px;\r\n            border: 4px solid #4caf50;\r\n            background: #81c784;\r\n            color: white;\r\n            cursor: pointer;\r\n            margin: 5px;\r\n            box-shadow: 0 6px #4caf50;\r\n            user-select: none;\r\n            -webkit-user-select: none;\r\n        }\r\n\r\n        button:active {\r\n            transform: translateY(4px);\r\n            box-shadow: 0 2px #4caf50;\r\n        }\r\n\r\n        canvas {\r\n            background: #a5d6a7;\r\n            border: 6px solid #2e7d32;\r\n            border-radius: 24px;\r\n            touch-action: none;\r\n            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.1);\r\n            display: block;\r\n            margin: 0 auto;\r\n        }\r\n\r\n        #hud {\r\n            display: flex;\r\n            justify-content: space-between;\r\n            align-items: center;\r\n            width: 95%;\r\n            margin: 5px auto;\r\n            font-size: 24px;\r\n            font-weight: bold;\r\n        }\r\n\r\n        #overlay {\r\n            position: fixed;\r\n            inset: 0;\r\n            background: rgba(0, 0, 0, 0.7);\r\n            display: none;\r\n            align-items: center;\r\n            justify-content: center;\r\n            z-index: 10;\r\n        }\r\n\r\n        #card {\r\n            background: #fff;\r\n            padding: 30px;\r\n            border-radius: 32px;\r\n            border: 6px solid #81c784;\r\n            max-width: 85%;\r\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);\r\n        }\r\n\r\n        #rule-box {\r\n            background: #fff9c4;\r\n            border: 4px solid #fbc02d;\r\n            padding: 12px;\r\n            border-radius: 20px;\r\n            font-size: 26px;\r\n            width: 95%;\r\n            margin: 0 auto 5px auto;\r\n            font-weight: bold;\r\n            box-sizing: border-box;\r\n            color: #f57f17;\r\n        }\r\n\r\n        /* Dpad styles removed (touch controls active on canvas) */\r\n    </style>\r\n</head>\r\n\r\n<body>\r\n\r\n    <div id=\"screen\" style=\"padding-top: 20vh;\">\r\n        <h1>🐸 Froggy Counting Adventure!</h1>\r\n        <p style=\"font-size: 22px; max-width: 450px; margin: 15px auto; font-weight: bold;\">\r\n            Help Froggy hop across the river!<br><br>\r\n            🔢 Count the items on the logs from 0 to 9 to cross safely!\r\n        </p>\r\n        <button id=\"start\" style=\"background: #ff7043; border-color: #d84315; box-shadow: 0 6px #d84315;\">▶ Play\r\n            Game!</button>\r\n    </div>\r\n\r\n    <div id=\"game\">\r\n        <div style=\"width: 100%;\">\r\n            <div id=\"rule-box\">🎯 Jump only on logs with ... items!</div>\r\n            <div id=\"hud\">\r\n                <span id=\"scoreEl\" style=\"color: #2e7d32;\">🐸 Score: 0/3</span>\r\n                <button id=\"pause\"\r\n                    style=\"padding: 6px 16px; font-size: 16px; border-radius: 12px; margin:0;\">Pause</button>\r\n            </div>\r\n        </div>\r\n\r\n        <canvas id=\"cv\"></canvas>\r\n\r\n        <!-- Dpad markup removed (direct swipe/tap touch controls active on canvas) -->\r\n    </div>\r\n\r\n    <div id=\"overlay\">\r\n        <div id=\"card\">\r\n            <h2 id=\"title\" style=\"font-size: 32px; margin-top: 0;\"></h2>\r\n            <div id=\"content\" style=\"font-size: 22px; font-weight: bold;\"></div>\r\n        </div>\r\n    </div>\r\n\r\n    <script>\r\n        const ROWS = 5, COLS = 8; // 5 rows total: 1 top bank, 3 river lanes, 1 bottom bank\r\n        const cv = document.getElementById('cv'), ctx = cv.getContext('2d');\r\n        const scoreEl = document.getElementById('scoreEl');\r\n        const pauseBtn = document.getElementById('pause');\r\n        const startBtn = document.getElementById('start');\r\n        const screenDiv = document.getElementById('screen');\r\n        const gameDiv = document.getElementById('game');\r\n        const overlay = document.getElementById('overlay');\r\n        const titleEl = document.getElementById('title');\r\n        const contentEl = document.getElementById('content');\r\n        const ruleBox = document.getElementById('rule-box');\r\n\r\n        let canvasWidth = 300;\r\n        let canvasHeight = 186;\r\n        let cellX = canvasWidth / COLS;\r\n        let cellY = canvasHeight / ROWS;\r\n\r\n        function resizeCanvas() {\r\n            canvasWidth = Math.floor(innerWidth * 0.95);\r\n            if (canvasWidth < 200) canvasWidth = 300;\r\n            if (canvasWidth > 330) canvasWidth = 330;\r\n            \r\n            canvasHeight = Math.floor(canvasWidth * 1.25);\r\n\r\n            cv.width = canvasWidth;\r\n            cv.height = canvasHeight;\r\n\r\n            cellX = canvasWidth / COLS;\r\n            cellY = canvasHeight / ROWS;\r\n        }\r\n\r\n        // Run once on load (with fallback values active)\r\n        resizeCanvas();\r\n\r\n        let frog, logs, score, run = false, paused = false;\r\n        let targetCount = 0;\r\n        const visualItems = ['⭐', '🍎', '🎈', '🐠', '🍬'];\r\n        let activeEmoji = '⭐';\r\n\r\n        function init() {\r\n            frog = { x: 4, y: 4 }; // Start at bottom bank (Row 4, center of 8 columns)\r\n            score = 0;\r\n            scoreEl.textContent = '🐸 Score: 0/3';\r\n            pickRandomMathTarget();\r\n\r\n            // Exactly 3 lanes of logs (wider width = cellX * 4.2)\r\n            logs = [\r\n                { y: 1, speed: canvasWidth * 0.0012, dir: -1, width: cellX * 4.2, x: 40 },\r\n                { y: 2, speed: canvasWidth * 0.0010, dir: 1, width: cellX * 4.2, x: 260 },\r\n                { y: 3, speed: canvasWidth * 0.0013, dir: -1, width: cellX * 4.2, x: 120 }\r\n            ];\r\n\r\n            logs.forEach(l => randomizeLogCount(l));\r\n        }\r\n\r\n        function pickRandomMathTarget() {\r\n            targetCount = Math.floor(Math.random() * 9) + 1;\r\n            activeEmoji = visualItems[Math.floor(Math.random() * visualItems.length)];\r\n\r\n            ruleBox.innerHTML = `🔢 Jump only on logs with <span style=\"color:#d84315\">${targetCount} ${activeEmoji}</span>`;\r\n        }\r\n\r\n        function randomizeLogCount(log) {\r\n            log.count = Math.floor(Math.random() * 9) + 1;\r\n        }\r\n\r\n        function draw() {\r\n            ctx.clearRect(0, 0, canvasWidth, canvasHeight);\r\n\r\n            // Riverbanks (Row 0 is Top, Row 4 is Bottom)\r\n            ctx.fillStyle = '#81c784';\r\n            ctx.fillRect(0, 0, canvasWidth, cellY);\r\n            ctx.fillRect(0, cellY * 4, canvasWidth, cellY);\r\n\r\n            // Blue River across center lanes (Rows 1-3)\r\n            ctx.fillStyle = '#29b6f6';\r\n            ctx.fillRect(0, cellY, canvasWidth, cellY * 3);\r\n\r\n            // Draw Logs\r\n            logs.forEach(log => {\r\n                ctx.fillStyle = '#8d6e63';\r\n                ctx.fillRect(log.x, log.y * cellY + 3, log.width, cellY - 6);\r\n\r\n                ctx.fillStyle = '#5d4037';\r\n                ctx.fillRect(log.x, log.y * cellY + 3, 10, cellY - 6);\r\n                ctx.fillRect(log.x + log.width - 10, log.y * cellY + 3, 10, cellY - 6);\r\n\r\n                // (Zero count drawing branch removed)\r\n\r\n                // Dynamic font sizing: Ensures emojis never overlap even with high numbers\r\n                const maxFontSize = cellY * 0.45;\r\n                const spacing = log.width / (log.count + 1);\r\n                const calculatedFontSize = Math.min(maxFontSize, spacing * 0.9);\r\n\r\n                ctx.font = `bold ${calculatedFontSize}px Arial`;\r\n                ctx.textAlign = 'center';\r\n                ctx.textBaseline = 'middle';\r\n\r\n                for (let i = 1; i <= log.count; i++) {\r\n                    ctx.fillText(activeEmoji, log.x + (spacing * i), log.y * cellY + cellY / 2);\r\n                }\r\n            });\r\n\r\n            // Draw Player Froggy\r\n            ctx.fillStyle = '#4caf50';\r\n            ctx.beginPath();\r\n            let fx = frog.x * cellX + cellX / 2;\r\n            let fy = frog.y * cellY + cellY / 2;\r\n            const frogRadius = cellX * 0.42;\r\n            ctx.arc(fx, fy, frogRadius, 0, Math.PI * 2);\r\n            ctx.fill();\r\n\r\n            // Eyes dynamically scaled to frogRadius\r\n            ctx.fillStyle = '#fff';\r\n            ctx.beginPath(); ctx.arc(fx - frogRadius * 0.4, fy - frogRadius * 0.5, frogRadius * 0.4, 0, Math.PI * 2); ctx.fill();\r\n            ctx.beginPath(); ctx.arc(fx + frogRadius * 0.4, fy - frogRadius * 0.5, frogRadius * 0.4, 0, Math.PI * 2); ctx.fill();\r\n            ctx.fillStyle = '#000';\r\n            ctx.beginPath(); ctx.arc(fx - frogRadius * 0.4, fy - frogRadius * 0.5, frogRadius * 0.18, 0, Math.PI * 2); ctx.fill();\r\n            ctx.beginPath(); ctx.arc(fx + frogRadius * 0.4, fy - frogRadius * 0.5, frogRadius * 0.18, 0, Math.PI * 2); ctx.fill();\r\n        }\r\n\r\n        function updatePhysics() {\r\n            logs.forEach(log => {\r\n                log.x += log.speed * log.dir;\r\n\r\n                if (log.dir === 1 && log.x > canvasWidth) {\r\n                    log.x = -log.width;\r\n                    randomizeLogCount(log);\r\n                } else if (log.dir === -1 && log.x < -log.width) {\r\n                    log.x = canvasWidth;\r\n                    randomizeLogCount(log);\r\n                }\r\n            });\r\n\r\n            if (frog.y >= 1 && frog.y <= 3) {\r\n                let currentLaneLog = logs[frog.y - 1];\r\n                let frogPixelX = frog.x * cellX + cellX / 2;\r\n\r\n                if (frogPixelX >= currentLaneLog.x && frogPixelX <= currentLaneLog.x + currentLaneLog.width) {\r\n                    if (currentLaneLog.count !== targetCount) {\r\n                        triggerSplash(`🔢 Oops! That log has ${currentLaneLog.count}!`);\r\n                        return;\r\n                    }\r\n                    let exactGridX = Math.floor((currentLaneLog.x + currentLaneLog.width / 2) / cellX);\r\n                    frog.x = Math.max(0, Math.min(COLS - 1, exactGridX));\r\n                } else {\r\n                    triggerSplash('💧 Splash! In the water!');\r\n                }\r\n            }\r\n        }\r\n\r\n        function triggerSplash(msg) {\r\n            paused = true;\r\n            overlay.style.display = 'flex';\r\n            titleEl.textContent = msg;\r\n            titleEl.style.color = '#d32f2f';\r\n\r\n            contentEl.innerHTML = `<p>Look for the log that has exactly ${targetCount} ${activeEmoji}! You can do it! 🌟</p><button onclick=\"dismissSplash()\">Try Again</button>`;\r\n        }\r\n\r\n        function dismissSplash() {\r\n            overlay.style.display = 'none';\r\n            frog = { x: 5, y: 4 };\r\n            paused = false;\r\n        }\r\n\r\n        function moveFrog(dx, dy) {\r\n            if (!run || paused) return;\r\n\r\n            frog.x = Math.max(0, Math.min(COLS - 1, frog.x + dx));\r\n            frog.y = Math.max(0, Math.min(ROWS - 1, frog.y + dy));\r\n\r\n            if (frog.y === 0) {\r\n                score++;\r\n                scoreEl.textContent = '🐸 Score: ' + score + '/3';\r\n                if (score >= 3) {\r\n                    endGame();\r\n                } else {\r\n                    paused = true;\r\n                    overlay.style.display = 'flex';\r\n                    titleEl.textContent = '🎉 Safe Across!';\r\n                    titleEl.style.color = '#388e3c';\r\n                    contentEl.innerHTML = '<p>Great counting! Ready for a new number? 🌟</p><button onclick=\"dismissSplash()\">Keep Going</button>';\r\n                    pickRandomMathTarget();\r\n                }\r\n            }\r\n        }\r\n\r\n        function endGame() {\r\n            run = false;\r\n            overlay.style.display = 'flex';\r\n            titleEl.textContent = '🏆 Math Champ! 🎉';\r\n            titleEl.style.color = '#388e3c';\r\n            contentEl.innerHTML = '<p>You counted all targets perfectly!</p><button class=\"large-btn\" onclick=\"restartGame()\">Play Again</button>';\r\n        }\r\n\r\n        function restartGame() {\r\n            overlay.style.display = 'none';\r\n            init();\r\n            run = true;\r\n        }\r\n\r\n        function loop() {\r\n            requestAnimationFrame(loop);\r\n            if (!run || paused) return;\r\n            updatePhysics();\r\n            draw();\r\n        }\r\n\r\n        screenDiv.style.display = 'block';\r\n        startBtn.addEventListener('click', function () {\r\n            screenDiv.style.display = 'none';\r\n            gameDiv.style.display = 'flex';\r\n            \r\n            // Re-calculate dimensions when the game container becomes active and visible\r\n            resizeCanvas();\r\n            \r\n            init();\r\n            run = true;\r\n        });\r\n\r\n        pauseBtn.addEventListener('click', function () {\r\n            if (!run) return;\r\n            paused = !paused;\r\n            pauseBtn.textContent = paused ? 'Play' : 'Pause';\r\n        });\r\n\r\n        // Tap to Hop function (tells Froggy to move in the direction tapped relative to his current position)\r\n        function handleTapMove(clickX, clickY) {\r\n            if (!run || paused) return;\r\n\r\n            const fx = frog.x * cellX + cellX / 2;\r\n            const fy = frog.y * cellY + cellY / 2;\r\n\r\n            const dx = clickX - fx;\r\n            const dy = clickY - fy;\r\n\r\n            const minTapDistance = 25; // Ignore tiny taps directly on the frog\r\n            if (Math.abs(dx) > Math.abs(dy)) {\r\n                if (Math.abs(dx) > minTapDistance) {\r\n                    if (dx > 0) moveFrog(1, 0);       // Tap Right of Frog\r\n                    else moveFrog(-1, 0);              // Tap Left of Frog\r\n                }\r\n            } else {\r\n                if (Math.abs(dy) > minTapDistance) {\r\n                    if (dy > 0) moveFrog(0, 1);       // Tap Down of Frog\r\n                    else moveFrog(0, -1);              // Tap Up of Frog\r\n                }\r\n            }\r\n        }\r\n\r\n        // Direct Canvas Gestures (support both swipe and tap on the river canvas)\r\n        let touchStartX = 0;\r\n        let touchStartY = 0;\r\n        let touchStartTime = 0;\r\n\r\n        cv.addEventListener('touchstart', (e) => {\r\n            e.preventDefault();\r\n            const touch = e.touches[0];\r\n            touchStartX = touch.clientX;\r\n            touchStartY = touch.clientY;\r\n            touchStartTime = Date.now();\r\n        }, { passive: false });\r\n\r\n        cv.addEventListener('touchend', (e) => {\r\n            e.preventDefault();\r\n            const touch = e.changedTouches[0];\r\n            const dx = touch.clientX - touchStartX;\r\n            const dy = touch.clientY - touchStartY;\r\n            const duration = Date.now() - touchStartTime;\r\n            \r\n            const swipeThreshold = 30; // Minimum swipe distance in pixels\r\n            \r\n            if (Math.abs(dx) > swipeThreshold || Math.abs(dy) > swipeThreshold) {\r\n                // Swipe detected\r\n                if (Math.abs(dx) > Math.abs(dy)) {\r\n                    if (dx > 0) moveFrog(1, 0);  // Swipe Right\r\n                    else moveFrog(-1, 0);         // Swipe Left\r\n                } else {\r\n                    if (dy > 0) moveFrog(0, 1);   // Swipe Down\r\n                    else moveFrog(0, -1);          // Swipe Up\r\n                }\r\n            } else if (duration < 250) {\r\n                // Short touch with minimal movement is treated as a Tap\r\n                const rect = cv.getBoundingClientRect();\r\n                const tx = touch.clientX - rect.left;\r\n                const ty = touch.clientY - rect.top;\r\n                handleTapMove(tx, ty);\r\n            }\r\n        }, { passive: false });\r\n\r\n        // Desktop mouse support for tapping\r\n        cv.addEventListener('mousedown', (e) => {\r\n            if ('ontouchstart' in window) return;\r\n            const rect = cv.getBoundingClientRect();\r\n            const mx = e.clientX - rect.left;\r\n            const my = e.clientY - rect.top;\r\n            handleTapMove(mx, my);\r\n        });\r\n\r\n        requestAnimationFrame(loop);\r\n    </script>\r\n</body>\r\n\r\n</html>",
