rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Scoped rules for security:
    
    // 1. Students collection: Allow students to create and update their profiles
    match /students/{studentId} {
      allow read, write: if true;
    }
    
    // 2. Games collection: Anyone can read, only authenticated admin accounts can write
    match /games/{gameId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // 3. Analytics collection: Anyone can log activity, only authenticated admin accounts can read
    match /analytics/{logId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // 4. Admin Settings collection: Only the authenticated admin user can read and write their own settings
    match /admin_settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 5. Notifications collection: Anyone can read/listen, only authenticated admin accounts can write
    match /notifications/{notiId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // 6. Game Requests collection: Students can submit ideas, only authenticated admins can manage/read
    match /game_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
